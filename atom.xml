&lt;p&gt;Youtube：&lt;a href=&quot;https://www.youtube.com/watch?v=ZTR5TCJ0Gy8&amp;amp;t=9&quot; target=&quot;_blank&quot; rel=&quot;noopener&quot;&gt;https://www.youtube.com/watch?v=ZTR5TCJ0Gy8&amp;amp;t=9&lt;/a&gt;&lt;/p&gt;
&lt;/blockquote&gt;
&lt;iframe src=&quot;//player.bilibili.com/player.html?aid=285814938&amp;bvid=BV1Hf4y1275k&amp;cid=195605581&amp;page=1&quot; height=&quot;500&quot; width=&quot;500&quot; scrolling=&quot;no&quot; border=&quot;0&quot; frameborder=&quot;no&quot; framespacing=&quot;0&quot; allowfullscreen=&quot;true&quot;&gt; &lt;/iframe&gt;
